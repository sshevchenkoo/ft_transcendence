# Скопируй этот файл:
#   cp terraform.tfvars.example terraform.tfvars
#
# terraform.tfvars НИКОГДА не коммить в git — он в .gitignore!

# Hetzner API токен (hetzner.com → Security → API Tokens → Read & Write)
hcloud_token = "вставь-hetzner-токен"

# Твой публичный IP — только с него будет открыт SSH
# Узнать: curl ifconfig.me
your_ssh_ip = "1.2.3.4"

# Опционально — можно оставить дефолты
# project_name    = "transcendence"
# location        = "nbg1"
# k3s_server_type = "cx22"
# db_server_type  = "cx22"
# os_image        = "ubuntu-24.04"
# network_zone    = "eu-central"

# Приватные IP — менять только если нужна другая подсеть
# master_private_ip  = "10.0.1.10"
# worker1_private_ip = "10.0.1.11"
# worker2_private_ip = "10.0.1.12"
# postgres_private_ip = "10.0.1.20"
# network_cidr       = "10.0.0.0/16"
# subnet_cidr        = "10.0.1.0/24"

# ssh_public_key НЕ указывается здесь — Makefile передаёт его автоматически:
#   -var="ssh_public_key=$(cat .ssh/id_ed25519.pub)"
