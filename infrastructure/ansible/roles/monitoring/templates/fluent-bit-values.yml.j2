config:
  # Read container logs from k3s nodes
  inputs: |
    [INPUT]
        Name              tail
        Path              /var/log/containers/*.log
        Parser            cri
        Tag               kube.*
        Mem_Buf_Limit     5MB
        Skip_Long_Lines   On
        Refresh_Interval  10

  # Parse Kubernetes metadata from the log path
  filters: |
    [FILTER]
        Name                kubernetes
        Match               kube.*
        Kube_URL            https://kubernetes.default.svc:443
        Kube_CA_File        /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
        Kube_Token_File     /var/run/secrets/kubernetes.io/serviceaccount/token
        Kube_Tag_Prefix     kube.var.log.containers.
        Merge_Log           On
        Keep_Log            Off
        Annotations         Off
        Labels              On

  # Ship to Logstash on ELK VM via TCP JSON
  outputs: |
    [OUTPUT]
        Name        tcp
        Match       kube.*
        Host        {{ elk_private_ip }}
        Port        5000
        Format      json_lines
        Retry_Limit 3

tolerations:
  - operator: Exists

resources:
  requests:
    cpu: 50m
    memory: 50Mi
  limits:
    cpu: 200m
    memory: 200Mi
