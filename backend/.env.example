DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/events
ANTHROPIC_API_KEY=sk-ant-...
# VOYAGE_API_KEY=   # once the embedding model is chosen
# APIFY_TOKEN=      # for the facebook_events adapter (apify.com → Settings → API tokens)
# TICKETMASTER_API_KEY=   # Consumer Key from developer.ticketmaster.com (Secret not needed)

# Auth (Google OAuth + signed-cookie sessions). Create an OAuth 2.0 "Web" client
# at console.cloud.google.com and add the redirect URI http://localhost:3000/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=change-me-to-a-long-random-string  # signs the session cookie
